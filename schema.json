{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bremen Schema Definitions",
  "definitions": {

    "Transaction": {
      "type": "object",
      "description": "Firestore コレクション: transactions/{transactionId}",
      "required": ["userId", "receiptDate", "payment", "category", "createdAt"],
      "properties": {
        "id":          { "type": "string", "description": "Firestore 自動生成 ID" },
        "userId":      { "type": "string", "description": "Firebase Auth UID" },
        "receiptDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "YYYY-MM-DD" },

        "store": {
          "type": "object",
          "properties": {
            "name":    { "type": "string" },
            "address": { "type": "string" },
            "phone":   { "type": "string" }
          }
        },

        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name":      { "type": "string" },
              "quantity":  { "type": "number", "minimum": 0 },
              "unitPrice": { "type": "number", "minimum": 0 },
              "subtotal":  { "type": "number", "minimum": 0 },
              "category":  { "type": "string" }
            }
          }
        },

        "payment": {
          "type": "object",
          "required": ["total"],
          "properties": {
            "subtotal": { "type": "number", "minimum": 0 },
            "tax":      { "type": "number", "minimum": 0 },
            "total":    { "type": "number", "minimum": 0 },
            "method":   { "type": "string", "enum": ["cash", "credit", "debit", "ic", "qr", "other"] }
          }
        },

        "category": {
          "type": "string",
          "enum": ["food", "transport", "entertainment", "health", "clothing", "household", "education", "other"]
        },

        "weather": {
          "type": ["object", "null"],
          "description": "取引日時点の気象データ（OpenWeatherMap）",
          "properties": {
            "condition":     { "type": "string", "description": "例: Clear, Rain, Clouds" },
            "conditionCode": { "type": "integer" },
            "description":   { "type": "string", "description": "日本語説明（lang=ja）" },
            "icon":          { "type": "string", "description": "OpenWeatherMap アイコン ID" },
            "temp":          { "type": "number", "description": "気温（℃）" },
            "feelsLike":     { "type": "number", "description": "体感温度（℃）" },
            "humidity":      { "type": "integer", "minimum": 0, "maximum": 100, "description": "湿度（%）" },
            "windSpeed":     { "type": "number", "description": "風速（m/s）" },
            "cloudiness":    { "type": "integer", "minimum": 0, "maximum": 100, "description": "雲量（%）" },
            "location":      { "type": "string", "description": "例: Tokyo, JP" },
            "lat":           { "type": "number" },
            "lon":           { "type": "number" },
            "fetchedAt":     { "type": "string", "description": "ISO 8601 取得日時" }
          }
        },

        "receipt": {
          "type": "object",
          "properties": {
            "imageUrl":    { "type": ["string", "null"], "description": "Firebase Storage ダウンロード URL" },
            "storagePath": { "type": ["string", "null"], "description": "Storage 内パス" },
            "ocrRawText":  { "type": ["string", "null"], "description": "Vision API の生テキスト" },
            "confidence":  { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
          }
        },

        "tags":       { "type": "array", "items": { "type": "string" } },
        "notes":      { "type": "string" },
        "isVerified": { "type": "boolean", "description": "ユーザーが内容を確認・修正したか" },
        "createdAt":  { "description": "Firestore Timestamp" },
        "updatedAt":  { "description": "Firestore Timestamp" }
      }
    },

    "Budget": {
      "type": "object",
      "description": "Firestore コレクション: budgets/{userId}_{YYYY-MM}",
      "required": ["userId", "month", "limits"],
      "properties": {
        "userId": { "type": "string" },
        "month":  { "type": "string", "pattern": "^\\d{4}-\\d{2}$", "description": "YYYY-MM" },
        "limits": {
          "type": "object",
          "description": "カテゴリごとの月次上限（円）",
          "properties": {
            "food":          { "type": "number", "minimum": 0 },
            "transport":     { "type": "number", "minimum": 0 },
            "entertainment": { "type": "number", "minimum": 0 },
            "health":        { "type": "number", "minimum": 0 },
            "clothing":      { "type": "number", "minimum": 0 },
            "household":     { "type": "number", "minimum": 0 },
            "education":     { "type": "number", "minimum": 0 },
            "other":         { "type": "number", "minimum": 0 },
            "total":         { "type": "number", "minimum": 0, "description": "全カテゴリの合計" }
          }
        },
        "createdAt": { "description": "Firestore Timestamp" },
        "updatedAt": { "description": "Firestore Timestamp" }
      }
    },

    "LineReceipt": {
      "type": "object",
      "description": "Firestore コレクション: lineReceipts/{docId}（LINEで送信されたレシート画像の受信箱、Cloud Functionsが作成）",
      "required": ["userId", "storagePath", "consumed", "createdAt"],
      "properties": {
        "userId":      { "type": "string", "description": "Firebase Auth UID" },
        "storagePath": { "type": "string", "description": "Storage 内パス（receipts/{uid}/...）" },
        "consumed":    { "type": "boolean", "description": "アプリの取引フォームで選択済みか" },
        "createdAt":   { "description": "Firestore Timestamp" }
      }
    },

    "AnalyzeReceiptRequest": {
      "type": "object",
      "description": "Cloud Functions: analyzeReceipt への入力",
      "required": ["imageUrl"],
      "properties": {
        "imageUrl":    { "type": "string" },
        "storagePath": { "type": "string" }
      }
    },

    "AnalyzeReceiptResponse": {
      "type": "object",
      "description": "Cloud Functions: analyzeReceipt からの返却値",
      "properties": {
        "receiptDate": { "type": "string" },
        "store":       { "$ref": "#/definitions/Transaction/properties/store" },
        "items":       { "$ref": "#/definitions/Transaction/properties/items" },
        "payment":     { "$ref": "#/definitions/Transaction/properties/payment" },
        "category":    { "$ref": "#/definitions/Transaction/properties/category" },
        "ocrRawText":  { "type": "string" },
        "confidence":  { "type": "number" }
      }
    }
  }
}
